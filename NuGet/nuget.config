<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Add your own private feed, for example:
    <add key="MyPrivateFeed" value="https://nuget.pkg.github.com/YourOrg/index.json" />
    -->
  </packageSources>
  <!-- Credentials for a private feed. Keep real tokens OUT of source control.
  <packageSourceCredentials>
    <MyPrivateFeed>
      <add key="Username" value="[Username]" />
      <add key="ClearTextPassword" value="[Token]" />
    </MyPrivateFeed>
  </packageSourceCredentials>
  -->
</configuration>
